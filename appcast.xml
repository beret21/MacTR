        <item>
            <title>MacTR 1.3.9</title>
            <sparkle:version>1.3.9</sparkle:version>
            <sparkle:shortVersionString>1.3.9</sparkle:shortVersionString>
            <description><![CDATA[
                <style>
                    body { font-family: -apple-system, BlinkMacSystemFont, sans-serif; font-size: 13px; color: #333; padding: 8px; }
